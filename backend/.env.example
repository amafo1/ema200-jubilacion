# Copia este archivo a .env y rellena tus valores.
# El archivo .env NO se sube a GitHub (está en .gitignore).

# Clave de Twelve Data (datos del S&P 500 para la EMA200)
TWELVE_DATA_API_KEY=tu_clave_twelve_data

# Clave de Brevo (envío de emails)
BREVO_API_KEY=tu_clave_brevo

# Email del administrador (recibe avisos y aprueba usuarios)
ADMIN_EMAIL=tu_email@ejemplo.com

# --- Base de datos ---
# En producción (Render/Railway) usa DATABASE_URL en su lugar.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ema200_jubilacion
DB_USER=postgres
DB_PASSWORD=postgres

# Secreto para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
